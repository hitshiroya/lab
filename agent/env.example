# ─────────────────────────────────────────
#  LLM Provider: "groq" or "ollama"
# ─────────────────────────────────────────
LLM_PROVIDER=groq

# ── Groq ──────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama ────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
